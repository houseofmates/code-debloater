{
  "name": "code-debloater",
  "version": "1.0.3",
  "description": "AST-driven structural code-bloat scanner powered by NVIDIA NIM (DeepSeek V4 Pro) — detects duplicate logic, lazy placeholders, and AI-generated stubs then auto-fixes them. Forked from zenapta/BloatHunter.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "code-debloater": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint --fix src",
    "start": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "minimatch": "^10.0.1",
    "picocolors": "^1.1.1",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.10.0",
    "tsx": "^4.7.0"
  },
  "keywords": [
    "code-quality",
    "linting",
    "debloat",
    "duplicate-code",
    "placeholder-detection",
    "nvidia-nim",
    "deepseek",
    "ast",
    "refactoring"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/houseofmates/code-debloater"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "author": "houseofmates (forked from zenapta/BloatHunter by Shashank Bhardwaj)"
}
